<script>
function clipURL() {
$('body').append('<textarea id="currentURL" style="position:fixed;left:-100%;">'+location.href+'</textarea>');
$('#currentURL').select();
document.execCommand('copy');
$('#currentURL').remove();
swal("URLをコピーしました。");
}
