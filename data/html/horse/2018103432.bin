<link rel="stylesheet" href="https://cdn.netkeiba.com/img.db/common/css/sweetalert_custom.css" type="text/css" media="screen">
<script src="https://cdn.netkeiba.com/img.db/common/js/sweetalert.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/encoding-japanese/2.0.0/encoding.min.js"></script>
<script>
$(function(){
var share_title = '';
var page_title = document.title;
if(page_title){
var ary_title = page_title.split('').map((v) => v.charCodeAt());
var encode_title = Encoding.convert(ary_title, 'UTF8', 'UNICODE');
share_title = Encoding.urlEncode(encode_title);
}
$("[id^='sns_']").click(function(){
var replace_url = '';
var cur_url = encodeURIComponent('https://db.netkeiba.com'+location.pathname+location.search+'&rf=share');
replace_url = $(this).attr('href').replace('_share_title_', share_title).replace('_share_url_', cur_url);
$(this).attr("href", replace_url);
});
// 共有ポップアップ
var current_scrollY;
$(".ShereBtn a").on("click", function(){
var msg = '';
var url = '';
if (typeof window.plugins === 'object') {
window.plugins.socialsharing.shareWithOptions({
message: msg,
url: url
});
return false;
}
current_scrollY = $(window).scrollTop();
$(".SherePopup01").addClass("OpenDraw");
$("#page").addClass("ViewOut");
$("#page.ViewOut").css({
top: -1 * current_scrollY,
height:'auto'
});
$("#page").append("<div class='ModalOverlay'></div>");
return false;
});
// 閉じる
$(document).on("touchend click", ".SherePopupCloseBtn,.ModalOverlay", function(){
$(".SherePopup01").removeClass("OpenDraw");
$("#page.ViewOut").attr({ style: ''}).removeClass("ViewOut");
$(".ModalOverlay").remove();
$('body').css({'position':'static'});
$( 'html, body' ).prop( { scrollTop: current_scrollY } );
return false;
event.preventDefault();
});
});
</script>
