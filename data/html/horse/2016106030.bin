<script type="text/javascript" src="https://cdn.netkeiba.com/img.db.sp/common/js/jquery.colorbox.js?20180321"></script>
<link rel="stylesheet" href="https://cdn.netkeiba.com/img.db.sp/common/css/sp/colorbox.css?20180321" type="text/css" media="screen">
<script type="text/javascript">
$(function(){
var is_sms_auth = 0; //sms認証
// sms認証
$('#photo_post').focusin(function(e) {
if (is_sms_auth) return;
e.preventDefault();
var _data = {
pid : 'api_check_sms_auth_status',
input : 'UTF-8',
output : 'jsonp',
};
$.ajax({
type : 'GET',
url : 'https://regist.sp.netkeiba.com',
data : _data,
dataType : _data.output,
success : function(data){
console.log(data);
if (data.status=="OK") {
if (!data.value) {
$.colorbox({
href:"https://regist.sp.netkeiba.com/?pid=post_sms_request",
iframe:true,
width: "94%",
height:"90%",
maxWidth:"360px",
maxHeight:"480px",
opacity: 0.7,
scrolling: true,
onOpen: function(){
$('#colorbox').addClass('sms_box');
},
onClosed: function(){
}
});
} else {
is_sms_auth = 1;
}
}
}
});
});
});
</script>

